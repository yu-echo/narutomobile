{
    "debug": {
        "next": "set_touchs"
    },
    "set_touchs": {
        "next": [
            "[JumpBack]close_touches",
            "[JumpBack]show_touches",
            "set_pointer_location"
        ],
        "timeout": 100
    },
    "close_touches": {
        "max_hit": 1,
        "focus": "关闭触控显示",
        "action": "Shell",
        "cmd": "settings put system show_touches 0",
        "next": "hide_pointer_location"
    },
    "show_touches": {
        "max_hit": 1,
        "enabled": false,
        "focus": "开启触控显示",
        "action": "Shell",
        "cmd": "settings put system show_touches 1"
    },
    "set_pointer_location": {
        "next": [
            "[JumpBack]hide_pointer_location",
            "[JumpBack]show_pointer_location",
            "others_settings"
        ]
    },
    "hide_pointer_location": {
        "focus": "隐藏指针位置",
        "max_hit": 1,
        "action": "Shell",
        "cmd": "settings put system pointer_location 0"
    },
    "show_pointer_location": {
        "focus": "显示指针位置",
        "max_hit": 1,
        "enabled": false,
        "action": "Shell",
        "cmd": "settings put system pointer_location 1"
    },
    "others_settings": {
        "action": "StopTask"
    }
}
